# HTTP / HTTPS 对外端口
HTTP_PORT=80
HTTPS_PORT=443

# 站点域名（HTTPS 与 CORS）
DOMAIN=relayagent.cloud
WWW_DOMAIN=www.relayagent.cloud
SSL_EMAIL=your@email.com

# ── agent-server ──────────────────────────────
PORT=3001
# SQLite（单 api 实例；数据文件在 deploy/data/relayagent.db，由 compose volume 持久化）
DATABASE_URL=file:./data/relayagent.db
DATA_DIR=./data

# LLM（OpenAI 兼容 API，如硅基流动）
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# JWT 密钥（生产环境必须修改）
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-me

# 管理员（首次 seed 使用）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
ADMIN_NICKNAME=Admin

# CORS，多个用逗号分隔（生产请改为 HTTPS 域名）
CORS_ORIGINS=https://www.relayagent.cloud,https://relayagent.cloud

# 企微机器人（可选）
WECOM_BOT_ID=
WECOM_BOT_SECRET=
WECOM_OWNER_USERID=
WECOM_GROUP_CHATID=

# ── OpenTelemetry（默认关闭）──────────────────
# 启用示例（指向 compose observability profile 的 collector）：
# RELAYAGENT_OTEL=1
# OTEL_METRICS_EXPORTER=otlp
# OTEL_TRACES_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
RELAYAGENT_OTEL=0
OTEL_SERVICE_NAME=relayagent-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRICS_EXPORTER=none
OTEL_TRACES_EXPORTER=none
