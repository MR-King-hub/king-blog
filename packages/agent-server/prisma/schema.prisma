// ═══════════════════════════════════════════════════════════════
// 📐 Prisma Schema — 数据库的"设计图"
// ═══════════════════════════════════════════════════════════════
//
// 什么是 Prisma？
//   一个 TypeScript ORM（Object-Relational Mapping）
//   你用 TypeScript 写查询，Prisma 帮你翻译成 SQL 执行
//   不用手写 SQL，还有完美的类型推导
//
// 什么是 Schema？
//   就是数据库的"设计图"，定义了：
//     - 用什么数据库（这里是 SQLite）
//     - 有哪些表（model）
//     - 每个表有哪些列（字段）
//     - 表之间的关系（一对多、多对多等）
//
// 工作流：
//   1. 修改这个文件（加表、加字段）
//   2. 运行 npx prisma migrate dev → 生成并执行迁移 SQL
//   3. Prisma 自动生成 TypeScript 类型，代码里直接用
// ═══════════════════════════════════════════════════════════════

// 数据源配置 — 使用 SQLite（一个文件就是一个数据库，最简单）
// 注意：Prisma 7 中，连接 URL 在 prisma.config.ts 中配置，这里只声明 provider
datasource db {
  provider = "sqlite"
}

// 客户端生成器 — 自动生成 TypeScript 类型
// Prisma 7 使用新的 "prisma-client" 生成器（替代旧的 "prisma-client-js"）
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"  // 输出到项目下的 generated 目录
}

// ══════════════════════════════════════════════════════════════
// 📊 数据模型（每个 model 对应数据库里的一张表）
// ══════════════════════════════════════════════════════════════

/// 用户表
model User {
  id           String   @id @default(uuid())  // 主键，自动生成 UUID
  email        String   @unique               // 邮箱，唯一（不允许重复注册）
  passwordHash String                         // 哈希后的密码
  nickname     String                         // 昵称
  role         String   @default("user")      // 角色：admin | user
  createdAt    DateTime @default(now())       // 创建时间，自动填充

  // 关系：一个用户可以有多篇文章
  articles     Article[]

  // 表名映射（Prisma 默认用 model 名作为表名）
  @@map("users")
}

/// 文章表
model Article {
  id         String   @id @default(uuid())
  slug       String   @unique                // URL 标识符，唯一
  title      String                          // 标题
  content    String                          // Markdown 正文
  summary    String   @default("")           // 摘要
  coverImage String?                         // 封面图（? 表示可选/可为 null）
  status     String   @default("draft")      // draft | published
  category   String?                         // 分类
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt             // 每次更新自动刷新时间

  // 关系：文章属于一个用户
  authorId   String?                         // 外键（可选，兼容无用户的历史数据）
  author     User?    @relation(fields: [authorId], references: [id])

  // 关系：文章可以有多个标签（多对多）
  tags       Tag[]

  @@map("articles")
}

/// 标签表
model Tag {
  id       String    @id @default(uuid())
  name     String    @unique                // 标签名，唯一

  // 关系：一个标签可以属于多篇文章（多对多）
  articles Article[]

  @@map("tags")
}

/// Agent 配置表（单例，只有一条记录）
model AgentConfig {
  id             String   @id @default("default")  // 固定 ID，保证单例
  name           String   @default("AI 助手")       // Agent 名称（显示在聊天窗口）
  greeting       String   @default("👋 你好！我是 Shizhe 的 AI 助手，有什么可以帮你的吗？")  // 打招呼语
  systemPrompt   String   @default("")              // 系统提示词（空则使用 default-agent-config.ts 中的默认模板）
  modelName      String   @default("")              // 留空则使用 LLM_MODEL 环境变量
  temperature    Float    @default(0.7)              // 温度（创造性）
  maxTokens      Int      @default(2000)             // 最大输出 token 数
  enabled        Boolean  @default(true)             // 是否启用（关闭后访客看不到聊天入口）
  rateLimit      Int      @default(20)               // 每 IP 每天最大对话次数

  // ── 企微通知配置 ──────────────────────────────
  wecomBotId       String  @default("")              // 企微智能机器人 Bot ID
  wecomBotSecret   String  @default("")              // 企微智能机器人长连接 Secret
  wecomOwnerUserId String  @default("")              // owner 的企微 userid（单聊推送）
  wecomGroupChatId String  @default("")              // 群聊 chatid（群聊推送，优先于单聊）

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("agent_config")
}

/// Agent 对话日志表（记录访客对话，方便管理员查看）
model ChatLog {
  id         String   @id @default(uuid())
  sessionId  String                         // 会话 ID
  role       String                         // user | assistant | system
  content    String                         // 消息内容
  ip         String   @default("")          // 访客 IP（用于频率限制）
  taskId     String?                        // 关联的任务 ID（null = 主对话消息）
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([ip, createdAt])
  @@map("chat_logs")
}

/// 待办任务表（Sub Agent 独立管理的审批/协调任务）
model PendingTask {
  id              String    @id @default(uuid())
  sessionId       String                        // 所属会话
  type            String                        // 任务类型：interview_schedule | referral_request | contact_request | ...
  visitorRequest  String                        // 访客的原始请求
  proposal        String    @default("")        // AI 的提案（JSON 字符串）
  status          String    @default("waiting_owner") // waiting_owner | resolved | expired
  imMessageId     String?                       // 推给 IM 后得到的消息 ID（用于路由回复）
  ownerReply      String?                       // 作者在 IM 最终确认的回复
  finalReply      String?                       // 给访客的最终回复
  deliveredVia    String?                       // chat | email | both
  visitorEmail    String?                       // 访客留的邮箱（可选）
  // Sub Agent 独立对话历史（JSON 数组，存 owner 与 agent 的多轮交互）
  conversationHistory String @default("[]")
  // 访客追加消息（JSON 数组，访客在等待期间发的后续消息）
  visitorMessages     String @default("[]")
  // Sub Agent 要问访客的问题（ask_visitor 时写入，访客回答后清空）
  pendingVisitorQuestion String @default("")
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  @@index([sessionId])
  @@index([imMessageId])
  @@index([status])
  @@map("pending_tasks")
}

/// 站点个人资料（单例，简历/关于页/首页 Hero）
model SiteProfile {
  id              String   @id @default("default")
  name            String   @default("Shizhe")
  tagline         String   @default("Full-stack · AI Explorer")
  headline        String   @default("Hi, 我是")
  heroSubtitle    String   @default("")
  location        String   @default("中国")
  role            String   @default("全栈工程师")
  experienceLabel String   @default("6+ 年经验")
  bioParagraphs   String   @default("[]")
  timeline        String   @default("[]")
  skillCategories String   @default("[]")
  interests       String   @default("[]")
  socialLinks     String   @default("[]")
  heroBento       String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("site_profile")
}

/// 项目作品表
model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  techStack   String   @default("[]")       // JSON 数组
  github      String?
  demo        String?
  stars       Int      @default(0)
  forks       Int      @default(0)
  featured    Boolean  @default(false)
  status      String   @default("draft")    // draft | published
  sortOrder   Int      @default(0)          // 排序权重，越小越前
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}
