{
  "name": "@relayagent/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for managing RelayAgent site content via REST API",
  "bin": {
    "relayagent-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@relayagent/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
