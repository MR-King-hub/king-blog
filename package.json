{
  "name": "relayagent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 10240; pkill -f 'tsx/dist' 2>/dev/null; pkill -f 'next-server' 2>/dev/null; sleep 2; pnpm --parallel -r run dev",
    "dev:web": "pnpm --filter @relayagent/web dev",
    "dev:server": "pnpm --filter @relayagent/agent-server dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @relayagent/web build",
    "build:server": "pnpm --filter @relayagent/agent-server build",
    "build:mcp": "pnpm --filter @relayagent/mcp build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm --filter @relayagent/web lint",
    "deploy": "bash deploy/deploy.sh",
    "deploy:build": "bash deploy/build-images.sh"
  },
  "engines": {
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "prisma"
    ]
  }
}
