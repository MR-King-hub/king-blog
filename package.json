{
  "name": "new-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:web": "pnpm --filter @blog/web dev",
    "dev:server": "pnpm --filter @blog/agent-server dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @blog/web build",
    "build:server": "pnpm --filter @blog/agent-server build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm --filter @blog/web lint"
  },
  "engines": {
    "pnpm": ">=9"
  }
}
