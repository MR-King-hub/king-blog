# 服务端口
PORT=3001

# ── LLM 配置 ──────────────────────────────────
# 支持任何 OpenAI 兼容 API（OpenAI / 硅基流动 / 其他代理）
# BASE_URL 填到 /chat/completions 的上一级即可
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=sk-xxxx
# Agent 默认模型（后台 modelName 留空时使用）
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# 数据存储目录
DATA_DIR=./data

# SQLite 数据库路径（Prisma provider = sqlite，单实例部署）
# 本地开发默认 ./dev.db；Docker 生产见 deploy/.env.example（file:./data/relayagent.db）
# ⚠️ 不要多个 api 进程/容器共享同一 .db 文件
DATABASE_URL="file:./dev.db"

# JWT 密钥（用于签名 token）
# ⚠️ 生产环境必须设置一个强密钥！可以用这个命令生成：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-me

# ── 管理员账号配置 ──────────────────────────
# 运行 `pnpm db:seed` 时会使用以下配置创建管理员
# ⚠️ 密码至少 8 个字符
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
ADMIN_NICKNAME=Admin

# 允许的前端域名（CORS），多个用逗号分隔
# 例如: https://yourdomain.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── 企微智能机器人配置（长连接模式）──────────────
# 当访客发起面试/内推等需要博主确认的请求时，
# 系统会通过企微机器人推送通知给你
WECOM_BOT_ID=
WECOM_BOT_SECRET=
# owner 的企微 userid（用于主动推送单聊消息）
# 需要 owner 先和机器人打过招呼才能主动推送
WECOM_OWNER_USERID=
# 群聊 chatid（把机器人拉进群后自动获取，也可手动填写）
# 配置后通知会优先发到群里，未配置则走单聊
WECOM_GROUP_CHATID=

# ── OpenTelemetry（默认关闭）──────────────────
# 双开关：RELAYAGENT_OTEL=1 且至少一个 exporter 为 otlp 才会导出
# 默认不导出 prompt / 回复正文，只记 model、agent、latency、token、status
RELAYAGENT_OTEL=0
OTEL_SERVICE_NAME=relayagent-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>
OTEL_METRICS_EXPORTER=none
OTEL_TRACES_EXPORTER=none
# OTEL_METRIC_EXPORT_INTERVAL=60000
