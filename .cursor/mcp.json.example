{
  "mcpServers": {
    "relayagent": {
      "url": "https://www.relayagent.cloud/mcp"
    },
    "relayagent-local": {
      "type": "stdio",
      "command": "node",
      "args": ["/path/to/relayagent/packages/mcp/dist/index.js"],
      "env": {
        "RELAYAGENT_API_URL": "http://localhost:3001",
        "RELAYAGENT_ADMIN_EMAIL": "admin@example.com",
        "RELAYAGENT_ADMIN_PASSWORD": "change-me-please"
      }
    }
  }
}
