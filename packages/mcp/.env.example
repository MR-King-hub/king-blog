# agent-server 地址
# 线上只读： https://www.relayagent.cloud
# 本地开发： http://localhost:3001
RELAYAGENT_API_URL=https://www.relayagent.cloud

# 只读模式（无需管理员账号，仅 list/get 工具）
RELAYAGENT_MCP_READONLY=true

# 管理员模式（取消只读后需填写，与 packages/agent-server/.env 中 ADMIN_* 一致）
# RELAYAGENT_ADMIN_EMAIL=admin@example.com
# RELAYAGENT_ADMIN_PASSWORD=change-me-please
