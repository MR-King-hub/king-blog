{
  "mcpServers": {
    "relayagent": {
      "command": "pnpm",
      "args": ["--filter", "@relayagent/mcp", "start"],
      "cwd": "/Users/shizhe/personal/relayagent",
      "env": {
        "RELAYAGENT_API_URL": "http://localhost:3001",
        "RELAYAGENT_ADMIN_EMAIL": "admin@example.com",
        "RELAYAGENT_ADMIN_PASSWORD": "change-me-please"
      }
    }
  }
}
